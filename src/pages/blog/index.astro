---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Group the (already date-descending) posts by year.
const groups: { year: number; items: typeof posts }[] = [];
for (const p of posts) {
  const year = p.data.date.getUTCFullYear();
  let g = groups.find((g) => g.year === year);
  if (!g) groups.push((g = { year, items: [] }));
  g.items.push(p);
}

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", timeZone: "UTC" });
---
<Base title="Blog">
  <h1 class="text-3xl font-bold mb-2">Blog</h1>
  <p class="mb-10 text-muted">
    Notes on computer vision, machine learning, robotics, and the systems behind them.
  </p>

  {posts.length === 0 && <p>No posts yet.</p>}

  {groups.map((g) => (
    <section class="mb-10">
      <h2 class="text-xl font-semibold leading-tight mb-4 pb-1.5 border-b border-rule">{g.year}</h2>
      <ul>
        {g.items.map((p) => (
          <li class="py-4 flex items-baseline gap-5 sm:gap-7">
            <time
              datetime={p.data.date.toISOString().slice(0, 10)}
              class="shrink-0 w-24 tabular-nums text-lg text-muted">
              {fmt(p.data.date)}
            </time>
            <div class="min-w-0">
              <a href={`/blog/${p.id}/`} class="group block">
                <h3 class="text-xl font-semibold leading-snug transition-opacity group-hover:opacity-80">{p.data.title}</h3>
              </a>
              <p class="text-lg text-muted leading-snug mt-1.5">{p.data.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>

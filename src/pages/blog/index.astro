---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric", timeZone: "UTC" });
---
<Base title="Blog">
  <h1 class="mb-2">Blog</h1>
  <p class="mb-8" style="color: var(--color-muted)">
    Notes on computer vision, machine learning, robotics, and the systems behind them.
  </p>

  {posts.length === 0 && <p>No posts yet.</p>}

  <ul class="divide-y" style="border-color: var(--color-border)">
    {posts.map((p) => (
      <li class="py-6">
        <a href={`/blog/${p.id}/`} class="group block">
          <h2 class="title-md mb-1 transition-opacity group-hover:opacity-80">{p.data.title}</h2>
        </a>
        <p class="text-base mb-2" style="color: var(--color-muted)">
          <time datetime={p.data.date.toISOString().slice(0, 10)}>{fmt(p.data.date)}</time>
          {p.data.tags.length > 0 && <span> · {p.data.tags.join(", ")}</span>}
        </p>
        <p class="text-[1.1rem] leading-snug" style="color: var(--color-muted)">{p.data.description}</p>
      </li>
    ))}
  </ul>
</Base>

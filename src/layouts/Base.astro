---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import SearchOverlay from "../components/SearchOverlay.astro";
import StructuredData from "../components/StructuredData.astro";

const {
  title,
  description = "Aditya Wagh — Research Engineer working on world models and spatial intelligence for embodied AI.",
  ogType = "website",
  image = "/images/profile.webp",
  datePublished,
  dateModified,
  keywords = [],
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="author" content="Aditya Wagh" />
  <title>{title}</title>
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/png" href="/icons/icon.png" />
  {/* Preload the body font (regular + bold) used above the fold so it arrives
      before first paint — cuts the LCP/CLS caused by ET Bembo swapping in late. */}
  <link rel="preload" href="/fonts/montaga.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="alternate" type="application/rss+xml" title="Aditya Wagh" href="/feed.xml" />
  <meta property="og:site_name" content="Aditya Wagh" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:site" content="@adityamwagh" />
  <StructuredData
    url={canonical}
    title={title}
    description={description}
    image={ogImage}
    ogType={ogType}
    pathname={Astro.url.pathname}
    datePublished={datePublished}
    dateModified={dateModified}
    keywords={keywords}
  />
  <ClientRouter />
  <!-- No-flash theme: runs before paint -->
  <script is:inline data-cfasync="false">
    (function () {
      try {
        var t = localStorage.getItem("theme");
        if (t === "light" || t === "dark") document.documentElement.setAttribute("data-theme", t);
      } catch (e) {}
    })();
  </script>
</head>
<body class="min-h-dvh flex flex-col">
  <Nav />
  <SearchOverlay />
  <main class="flex-1 w-full container mx-auto max-w-3xl px-6">
    <article class="fade-in-up py-12">
      <slot />
    </article>
  </main>
  <Footer />
  <script>
    // Work-page behaviour lives here (not in work.astro) so it loads on every
    // page. Astro's ClientRouter does not execute a destination page's own
    // inline script on client-side navigation, so a /work-only script never
    // bound when /work was reached via nav. Bound once on document here, it
    // works no matter how /work is reached.
    function bindWorkTabs() {
      if ((window as any).__workTabsBound) return;
      (window as any).__workTabsBound = true;
      document.addEventListener("click", (e) => {
        const tab = (e.target as Element)?.closest?.(".work-tab");
        if (!tab) return;
        const target = tab.getAttribute("data-tab");
        document.querySelectorAll<HTMLElement>(".work-tab").forEach((t) => {
          const active = t === tab;
          t.classList.toggle("is-active", active);
          t.setAttribute("aria-selected", active ? "true" : "false");
        });
        document.querySelectorAll<HTMLElement>("[data-panel]").forEach((panel) => {
          const show = panel.getAttribute("data-panel") === target;
          panel.hidden = !show;
          if (show) {
            panel.classList.remove("fade-in-up");
            void panel.offsetWidth; // force reflow so the animation restarts
            panel.classList.add("fade-in-up");
          }
        });
      });
    }

    // GitHub star counts, cached per repo in localStorage for 24h. Runs on each
    // page load; no-ops on pages without star badges.
    function loadStars() {
      const DAY = 86400000;
      document.querySelectorAll<HTMLElement>(".star-badge[data-repo]").forEach(async (el) => {
        const repo = el.getAttribute("data-repo");
        if (!repo) return;
        const key = "gh-stars:" + repo;
        let count: number | null = null;
        try {
          const cached = JSON.parse(localStorage.getItem(key) || "null");
          if (cached && Date.now() - cached.ts < DAY) count = cached.count;
        } catch {}
        if (count == null) {
          try {
            const res = await fetch(`https://api.github.com/repos/${repo}`);
            if (!res.ok) return;
            const data = await res.json();
            count = data.stargazers_count;
            try { localStorage.setItem(key, JSON.stringify({ count, ts: Date.now() })); } catch {}
          } catch { return; }
        }
        if (count == null) return;
        const c = el.querySelector(".star-count");
        if (c) c.textContent = count >= 1000 ? (count / 1000).toFixed(1).replace(/\.0$/, "") + "k" : String(count);
        el.hidden = false;
      });
    }

    bindWorkTabs();
    loadStars();
    document.addEventListener("astro:page-load", () => { bindWorkTabs(); loadStars(); });
  </script>
  <!-- Cloudflare Web Analytics -->
  <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "63d568ab4f0b4139bbb58eaff605d429"}'></script>
</body>
</html>

---
import { themeIcons, themeOptions } from "../data/theme-icons";
---
<div class="theme-menu relative" data-theme-menu>
  <button
    class="theme-menu__button cursor-pointer hover:opacity-100 opacity-80 transition-opacity whitespace-nowrap"
    type="button" data-theme-menu-button data-theme-mode="system"
    aria-haspopup="true" aria-expanded="false" aria-label="Theme">
    <span class="theme-menu__icon inline-flex align-middle" data-theme-icon set:html={themeIcons.system} />
    <span class="align-middle ml-1.5">Theme</span>
    <svg class="inline-block align-middle ml-1" width="0.7em" height="0.7em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"></path></svg>
  </button>
  <ul
    class="theme-menu__list absolute right-0 mt-2 min-w-[9rem] rounded-xl border border-rule bg-page py-1.5 z-50 shadow-md"
    role="menu" aria-label="Theme">
    {themeOptions.map((o) => (
      <li role="none">
        <button
          class="theme-menu__option flex items-center justify-center gap-2 w-full px-3 py-1.5 text-center text-base hover:opacity-100 opacity-80 cursor-pointer"
          type="button" data-theme-option={o.mode} role="menuitemradio" aria-checked={o.mode === "system" ? "true" : "false"}>
          <span class="inline-flex" set:html={themeIcons[o.mode]} />
          <span>{o.label}</span>
        </button>
      </li>
    ))}
  </ul>
</div>

<script>
  import { themeIcons } from "../data/theme-icons";
  const STORAGE_KEY = "theme";
  const MODES = ["system", "light", "dark"];

  function getStoredMode(): string {
    try {
      const v = localStorage.getItem(STORAGE_KEY);
      return v && MODES.includes(v) ? v : "system";
    } catch {
      return "system";
    }
  }
  function setStoredMode(mode: string) {
    try {
      if (mode === "system") localStorage.removeItem(STORAGE_KEY);
      else localStorage.setItem(STORAGE_KEY, mode);
    } catch {}
  }
  function applyMode(mode: string) {
    if (mode === "light" || mode === "dark") document.documentElement.setAttribute("data-theme", mode);
    else document.documentElement.removeAttribute("data-theme");
  }

  function closeAll() {
    document.querySelectorAll(".theme-menu__list").forEach((l) => l.classList.remove("is-open"));
    document.querySelectorAll("[data-theme-menu-button]").forEach((b) => b.setAttribute("aria-expanded", "false"));
  }
  function updateUI(mode: string) {
    document.querySelectorAll<HTMLElement>("[data-theme-option]").forEach((opt) => {
      opt.setAttribute("aria-checked", opt.getAttribute("data-theme-option") === mode ? "true" : "false");
    });
    document.querySelectorAll<HTMLElement>("[data-theme-menu-button]").forEach((btn) => {
      btn.setAttribute("data-theme-mode", mode);
      const icon = btn.querySelector("[data-theme-icon]");
      if (icon) icon.innerHTML = themeIcons[mode as keyof typeof themeIcons];
    });
  }
  // Enable the colour cross-fade only for a user toggle. Adding the class to
  // <html> turns on transitions for ~320ms so header + body + borders fade in
  // lockstep (no flicker), then removes it so navigation never animates colours.
  let themeFadeTimer: number | undefined;
  function flashThemeFade() {
    const el = document.documentElement;
    el.classList.add("theme-transition");
    if (themeFadeTimer) clearTimeout(themeFadeTimer);
    themeFadeTimer = window.setTimeout(() => el.classList.remove("theme-transition"), 320);
  }
  function setMode(mode: string) {
    flashThemeFade();
    setStoredMode(mode);
    applyMode(mode);
    updateUI(mode);
  }
  // Re-sync the controls to the stored mode after every (re)render — the DOM is
  // swapped on View-Transition navigation, so the new buttons need their icons
  // and checked-states reapplied.
  function syncTheme() {
    const current = getStoredMode();
    applyMode(current);
    updateUI(current);
  }

  // Delegated on `document`, bound exactly once. Inline scripts re-run on Astro
  // View-Transition navigation; per-element binding would stack duplicate
  // listeners. Each button finds its own dropdown via its parent `.theme-menu`,
  // so both the desktop and mobile-menu instances work from one handler.
  function bindThemeMenu() {
    if ((window as any).__themeMenuBound) return;
    (window as any).__themeMenuBound = true;

    // Ignore iOS Safari's ~300ms ghost click so a tap can't open then
    // immediately re-close the dropdown.
    let lastBtnAt = 0;

    document.addEventListener("click", (e) => {
      const target = e.target as Element | null;
      const opt = target?.closest?.("[data-theme-option]");
      if (opt) {
        e.stopPropagation();
        setMode(opt.getAttribute("data-theme-option") || "system");
        closeAll();
        return;
      }
      const btn = target?.closest?.("[data-theme-menu-button]") as HTMLElement | null;
      if (btn) {
        e.stopPropagation();
        if (Date.now() - lastBtnAt < 400) return;
        lastBtnAt = Date.now();
        const willOpen = btn.getAttribute("aria-expanded") !== "true";
        closeAll();
        if (willOpen) {
          btn.parentElement?.querySelector(".theme-menu__list")?.classList.add("is-open");
          btn.setAttribute("aria-expanded", "true");
        }
        return;
      }
      // Click anywhere else dismisses any open dropdown.
      closeAll();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeAll();
    });
  }

  syncTheme();
  bindThemeMenu();
  document.addEventListener("astro:page-load", syncTheme);
  document.addEventListener("astro:page-load", bindThemeMenu);
</script>

<style>
  .theme-menu__list {
    opacity: 0;
    visibility: hidden;
    transform: scale(0.95) translateY(-4px);
    transform-origin: top right;
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
  }
  .theme-menu__list.is-open {
    opacity: 1;
    visibility: visible;
    transform: scale(1) translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .theme-menu__list { transition: none; }
  }
</style>

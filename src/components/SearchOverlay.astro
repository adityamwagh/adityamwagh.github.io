---
// Pagefind assets are generated by the `pagefind --site dist` postbuild step.
// They live at /pagefind/* and only exist after a production build (404 in dev — harmless).
---
<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

<div
  class="search-overlay fixed inset-0 z-[100] hidden items-start justify-center p-4 sm:p-8"
  style="background: color-mix(in srgb, var(--color-bg) 70%, transparent); backdrop-filter: blur(4px)"
  data-search-overlay hidden>
  <div
    class="search-panel w-full max-w-2xl mt-[10vh] rounded-lg border p-5 shadow-lg"
    style="background: var(--color-bg); border-color: var(--color-border)"
    role="dialog" aria-modal="true" aria-labelledby="search-title">
    <div class="flex items-center justify-between mb-3">
      <h2 id="search-title">Search</h2>
      <button class="cursor-pointer opacity-70 hover:opacity-100" type="button" data-search-close aria-label="Close search">
        <svg viewBox="0 0 24 24" width="1.4em" height="1.4em" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12"></path><path d="M18 6l-12 12"></path></svg>
      </button>
    </div>
    <div id="pagefind-search"></div>
  </div>
</div>

<style is:global>
  /* Theme Pagefind UI to match the site accent + tokens */
  .pagefind-ui {
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-bg);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-font: "ET Bembo", Georgia, serif;
  }
</style>

<script>
  function init() {
    const overlay = document.querySelector<HTMLElement>("[data-search-overlay]");
    if (!overlay) return;

    const openButtons = document.querySelectorAll<HTMLElement>("[data-search-open]");
    const closeButton = overlay.querySelector<HTMLElement>("[data-search-close]");
    let pagefindUI: any = null;

    function createUI() {
      if (pagefindUI) return;
      pagefindUI = new (window as any).PagefindUI({
        element: "#pagefind-search",
        showSubResults: true,
        showImages: false,
        resetStyles: false,
        translations: { placeholder: "Search posts and pages..." },
      });
    }
    function initPagefind() {
      if (pagefindUI) return;
      if (typeof (window as any).PagefindUI !== "undefined") return createUI();
      let script = document.getElementById("pagefind-ui-script") as HTMLScriptElement | null;
      if (!script) {
        script = document.createElement("script");
        script.id = "pagefind-ui-script";
        script.src = "/pagefind/pagefind-ui.js";
        document.head.appendChild(script);
      }
      script.addEventListener("load", createUI, { once: true });
    }
    function open() {
      initPagefind();
      overlay!.hidden = false;
      overlay!.classList.remove("hidden");
      overlay!.classList.add("flex");
      document.body.style.overflow = "hidden";
      // Replay the same entrance animation used on page navigation / tab switch.
      const panel = overlay!.querySelector<HTMLElement>(".search-panel");
      if (panel) {
        panel.classList.remove("fade-in-up");
        void panel.offsetWidth;
        panel.classList.add("fade-in-up");
      }
      setTimeout(() => {
        const input = overlay!.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
        input?.focus();
      }, 50);
    }
    function close() {
      overlay!.classList.add("hidden");
      overlay!.classList.remove("flex");
      overlay!.hidden = true;
      document.body.style.overflow = "";
    }

    openButtons.forEach((b) => b.addEventListener("click", open));
    closeButton?.addEventListener("click", close);
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) close();
    });

    if (!(window as any).__searchEscBound) {
      (window as any).__searchEscBound = true;
      document.addEventListener("keydown", (e) => {
        const o = document.querySelector<HTMLElement>("[data-search-overlay]");
        if (o && !o.hidden && e.key === "Escape") {
          o.classList.add("hidden");
          o.classList.remove("flex");
          o.hidden = true;
          document.body.style.overflow = "";
        }
      });
    }
  }

  document.addEventListener("astro:page-load", init);
</script>

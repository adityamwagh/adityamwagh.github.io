---
// Pagefind assets are generated by the `pagefind --site dist` postbuild step.
// They live at /pagefind/* and only exist after a production build (404 in dev — harmless).
---
<div
  class="search-overlay fixed inset-0 z-[100] hidden items-start justify-center p-4 sm:p-8 bg-scrim backdrop-blur-sm"
  data-search-overlay hidden>
  <div
    class="search-panel w-full max-w-2xl mt-[10vh] rounded-lg border border-rule bg-page p-5 shadow-lg"
    role="dialog" aria-modal="true" aria-labelledby="search-title">
    <div class="flex items-center justify-between mb-3">
      <h2 id="search-title">Search</h2>
      <button class="cursor-pointer opacity-70 hover:opacity-100" type="button" data-search-close aria-label="Close search">
        <svg viewBox="0 0 24 24" width="1.4em" height="1.4em" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12"></path><path d="M18 6l-12 12"></path></svg>
      </button>
    </div>
    <div id="pagefind-search"></div>
  </div>
</div>

<style is:global>
  /* Theme Pagefind UI to match the site accent + tokens */
  .pagefind-ui {
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-bg);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-font: "ET Bembo", Georgia, serif;
  }
</style>

<script>
  // Delegated on `document` and bound exactly once. Astro's View-Transition
  // router re-runs inline component scripts on client navigation; the old
  // per-element binding inside `astro:page-load` re-attached open/close
  // handlers each navigation. Delegation + a one-time guard avoids the
  // duplicate listeners, and keeping `pagefindUI` in this single closure means
  // the index is built only once for the whole session.
  function bindSearch() {
    if ((window as any).__searchBound) return;
    (window as any).__searchBound = true;

    let pagefindUI: any = null;
    // iOS Safari fires a synthesized "ghost" click ~300ms after a tap at the
    // same coordinates. The tap that opens the overlay would otherwise land a
    // ghost click on the backdrop and immediately close it. Ignore backdrop
    // closes that happen within this window of opening.
    let openedAt = 0;

    function createUI() {
      if (pagefindUI) return;
      pagefindUI = new (window as any).PagefindUI({
        element: "#pagefind-search",
        showSubResults: true,
        showImages: false,
        resetStyles: false,
        translations: { placeholder: "Search posts and pages..." },
      });
    }
    function initPagefind() {
      if (pagefindUI) return;
      // Load Pagefind's stylesheet on demand so it never blocks first render
      // (it's only needed once the search overlay is opened).
      if (!document.getElementById("pagefind-ui-css")) {
        const css = document.createElement("link");
        css.id = "pagefind-ui-css";
        css.rel = "stylesheet";
        css.href = "/pagefind/pagefind-ui.css";
        document.head.appendChild(css);
      }
      if (typeof (window as any).PagefindUI !== "undefined") return createUI();
      let script = document.getElementById("pagefind-ui-script") as HTMLScriptElement | null;
      if (!script) {
        script = document.createElement("script");
        script.id = "pagefind-ui-script";
        script.src = "/pagefind/pagefind-ui.js";
        document.head.appendChild(script);
      }
      script.addEventListener("load", createUI, { once: true });
    }
    function open() {
      const overlay = document.querySelector<HTMLElement>("[data-search-overlay]");
      if (!overlay) return;
      initPagefind();
      overlay.hidden = false;
      overlay.classList.remove("hidden");
      overlay.classList.add("flex");
      openedAt = Date.now();
      document.body.style.overflow = "hidden";
      // Replay the same entrance animation used on page navigation / tab switch.
      const panel = overlay.querySelector<HTMLElement>(".search-panel");
      if (panel) {
        panel.classList.remove("fade-in-up");
        void panel.offsetWidth;
        panel.classList.add("fade-in-up");
      }
      setTimeout(() => {
        const input = overlay.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
        input?.focus();
      }, 50);
    }
    function close() {
      const overlay = document.querySelector<HTMLElement>("[data-search-overlay]");
      if (!overlay) return;
      overlay.classList.add("hidden");
      overlay.classList.remove("flex");
      overlay.hidden = true;
      document.body.style.overflow = "";
    }

    document.addEventListener("click", (e) => {
      const target = e.target as Element | null;
      if (target?.closest?.("[data-search-open]")) { open(); return; }
      if (target?.closest?.("[data-search-close]")) { close(); return; }
      // A click on the backdrop itself (not the panel) closes the overlay —
      // unless it's the iOS ghost click from the tap that just opened it.
      const overlay = document.querySelector<HTMLElement>("[data-search-overlay]");
      if (overlay && target === overlay && Date.now() - openedAt > 400) close();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      const o = document.querySelector<HTMLElement>("[data-search-overlay]");
      if (o && !o.hidden) close();
    });
  }
  bindSearch();
  document.addEventListener("astro:page-load", bindSearch);
</script>
